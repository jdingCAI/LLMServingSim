# Ignore env file
env/

# Ignore python cache
*.pyc
__pycache__/
*.joblib

# Ignore pkl files
*.pkl

# Allow runtime-required perf-model artifacts
!llm_profile/perf_models/**/*.joblib
!llm_profile/perf_models/**/*.pkl

# Ignore sweep outputs (regenerated by run_h200_sensitivity_sweep.sh + analyzer)
output/

# Ignore generated datasets (regenerated by dataset/generate_synthetic_multi_turn.py)
dataset/*.jsonl
